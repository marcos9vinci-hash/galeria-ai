{
  "entities": {
    "ScheduledPost": {
      "title": "Scheduled Post",
      "description": "A scheduled post for Instagram",
      "type": "object",
      "properties": {
        "igId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "caption": { "type": "string" },
        "token": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "published": { "type": "boolean" },
        "error": { "type": "string" }
      },
      "required": ["igId", "imageUrl", "scheduledAt", "published"]
    },
    "UserPost": {
      "title": "User Post",
      "description": "A post stored by the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "image": { "type": "string" },
        "caption": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["userId", "image", "date", "status"]
    }
  },
  "firestore": {
    "/scheduledPosts/{postId}": {
      "schema": { "$ref": "ScheduledPost" },
      "description": "Collection of scheduled Instagram posts"
    },
    "/posts/{postId}": {
      "schema": { "$ref": "UserPost" },
      "description": "Collection of user posts"
    }
  }
}
