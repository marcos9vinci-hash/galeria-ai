{
  "entities": {
    "ScheduleSlot": {
      "title": "Schedule Slot",
      "description": "A pre-defined slot for a social media post.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["empty", "filled", "posted"] },
        "postId": { "type": "string" }
      },
      "required": ["userId", "scheduledAt", "status"]
    }
  },
  "firestore": {
    "/scheduleSlots/{slotId}": {
      "schema": { "$ref": "ScheduleSlot" },
      "description": "Pre-defined scheduling slots for content."
    }
  }
}
